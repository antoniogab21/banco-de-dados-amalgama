# MySQL connection example
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=amalgama
MYSQL_USER=amalgama
MYSQL_PASSWORD=amalgama_pass

# Application DATABASE URL (example for SQLAlchemy / SQLAlchemy URL style)
# Use this in your backend config to point to MySQL (do not commit real secrets)
# Example: mysql+pymysql://amalgama:amalgama_pass@localhost:3306/amalgama
DATABASE_URL=mysql+pymysql://amalgama:amalgama_pass@localhost:3306/amalgama
# Exemplo de arquivo de configuração de ambiente
# Copie este arquivo para .env e ajuste os valores conforme necessário

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=amalgama